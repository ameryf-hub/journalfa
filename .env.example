# Copy this file to .env for local development.
# In production, set these values as Railway variables.

# Railway Postgres connection string.
DATABASE_URL=

# Single-user auth for the journal.
APP_USERNAME=
APP_PASSWORD=
SESSION_SECRET=

# Comma-separated list of allowed CORS origins.
# Example: https://your-app.up.railway.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Environment mode: development | production
NODE_ENV=development

# Port the server listens on (Railway sets this automatically)
PORT=3000
