# Copy this file to .env and fill in real values for local development.
# In production (Railway) and Codespaces, set these as platform secrets instead.
# Do NOT commit your real .env file.

# Financial Modeling Prep API key (required)
FMP_API_KEY=

# Comma-separated list of allowed CORS origins.
# Example: https://your-app.up.railway.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Environment mode: development | production
NODE_ENV=development

# Port the server listens on (Railway sets this automatically)
PORT=3000
